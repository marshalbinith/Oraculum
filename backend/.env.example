# ── Stellar Network ────────────────────────────────────────────────
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ── Deployed Contract Addresses (fill from .env.deployed) ───────────
FACTORY_ADDRESS=
ORACLE_REGISTRY_ADDRESS=
USDC_TOKEN_ADDRESS=

# ── Indexer ─────────────────────────────────────────────────────────
INDEXER_START_LEDGER=0
INDEXER_POLL_INTERVAL_MS=5000

# ── Oracle Operator (price relay) ──────────────────────────────────
ORACLE_OPERATOR_SECRET_KEY=
PROTOCOL_TREASURY_ADDRESS=

# ── Datastores ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stellarpredict
REDIS_URL=redis://localhost:6379

# ── Server ──────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=100
